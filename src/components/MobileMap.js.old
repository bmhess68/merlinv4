// Create a component to handle marker styles
function MarkerStyles() {
    useEffect(() => {
        // Check if the style element already exists
        let styleElement = document.getElementById('marker-styles');
        
        if (!styleElement) {
            // Create it if it doesn't exist
            styleElement = document.createElement('style');
            styleElement.id = 'marker-styles';
            document.head.appendChild(styleElement);
        }
        
        // Update the content
        styleElement.textContent = `
            .emoji-pin-marker {
                filter: drop-shadow(0 2px 3px rgba(0,0,0,0.3));
            }
            
            .emoji-pin-marker div {
                transform: translateY(-4px);
            }
            
            /* Make sure the tooltip is visible */
            .leaflet-tooltip {
                background-color: rgba(25, 25, 25, 0.8);
                color: white;
                border: none;
                border-radius: 10px;
                padding: 5px 10px;
                font-weight: bold;
                box-shadow: 0 2px 5px rgba(0,0,0,0.3);
            }
            
            .leaflet-tooltip-top:before {
                border-top-color: rgba(25, 25, 25, 0.8);
            }
        `;
        
        return () => {
            // Only remove if this is the last instance
            if (document.getElementById('marker-styles')) {
                document.head.removeChild(styleElement);
            }
        };
    }, []);
    
    return null;
}

// Component to handle map constraints (zoom/pan limits)
function MapConstraints({ followedVehicle, disablePan }) {
    const map = useMap();
    
    // Disable panning based on prop
    useEffect(() => {
        if (disablePan || followedVehicle) {
            // Disable map interactions when following or when disablePan is true
            map.dragging.disable();
            map.touchZoom.disable();
            map.doubleClickZoom.disable();
            map.scrollWheelZoom.disable();
            map.boxZoom.disable();
            map.keyboard.disable();
            
            return () => {
                // Re-enable map interactions when not following and disablePan is false
                map.dragging.enable();
                map.touchZoom.enable();
                map.doubleClickZoom.enable();
                map.scrollWheelZoom.enable();
                map.boxZoom.enable();
                map.keyboard.enable();
            };
        }
    }, [followedVehicle, map, disablePan]);
    
    useMapEvents({
        zoom: () => {
            // Enforce zoom constraints (16-18 as requested)
            const currentZoom = map.getZoom();
            console.log('Current zoom level:', currentZoom);
            if (currentZoom < 15) {
                map.setZoom(15);
            } else if (currentZoom > 18) {
                map.setZoom(18);
            }
        },
        dragstart: (e) => {
            // Prevent panning when following a vehicle or when disablePan is true
            if ((followedVehicle || disablePan) && e && e.originalEvent) {
                e.originalEvent.preventDefault();
            } else if (followedVehicle || disablePan) {
                // Alternative approach if originalEvent is not available
                map.dragging.disable();
                
                // Re-enable dragging after a short delay to prevent getting stuck
                setTimeout(() => {
                    if (map && followedVehicle) {
                        map.panTo([followedVehicle.latitude, followedVehicle.longitude]);
                    }
                }, 100);
            }
        }
    });
    
    return null;
}

// Component to get user's current location and initialize the map
function LocationFinder() {
    const map = useMap();
    
    useEffect(() => {
        // Get current location
        map.locate({ setView: true, maxZoom: 16 });
        
        // Add event handler for when location is found
        function onLocationFound(e) {
            console.log("Location found:", e.latlng);
            map.setView(e.latlng, 17);
            
            // Force map invalidation after a slight delay
            setTimeout(() => {
                console.log("Invalidating map size");
                map.invalidateSize(true);
            }, 200);
        }
        
        map.on('locationfound', onLocationFound);
        
        return () => {
            map.off('locationfound', onLocationFound);
        };
    }, [map]);
    
    return null;
}

// Updated StatusBar component with intersection and highway exit information
const StatusBar = ({ followedVehicle }) => {
    // Format heading as compass direction
    const getCompassDirection = (degrees) => {
        if (degrees === undefined || degrees === null) return 'N/A';
        
        const directions = ['N', 'NNE', 'NE', 'ENE', 'E', 'ESE', 'SE', 'SSE', 'S', 'SSW', 'SW', 'WSW', 'W', 'WNW', 'NW', 'NNW'];
        const index = Math.round((degrees % 360) / 22.5) % 16;
        return directions[index];
    };

    // Glass effect style base
    const glassEffect = {
        backgroundColor: 'rgba(25, 25, 25, 0.8)',
        backdropFilter: 'blur(10px)',
        WebkitBackdropFilter: 'blur(10px)',
        borderRadius: '20px',
        boxShadow: '0 4px 15px rgba(0, 0, 0, 0.2)',
        border: '1px solid rgba(255, 255, 255, 0.15)'
    };
    
    // Move status bar higher to avoid overlap with bottom buttons and increase size by 1.5X
    const statusBarStyle = {
        position: 'fixed',
        bottom: '80px', // Higher position to accommodate larger size
        left: '50%',
        transform: 'translateX(-50%)',
        width: '85%',
        padding: '15px 21px', // 1.5X from original 10px 14px
        color: 'white',
        zIndex: 999,
        display: 'flex',
        flexDirection: 'column',
        maxWidth: '600px',
        ...glassEffect
    };
    
    const emptyStatusStyle = {
        ...statusBarStyle,
        justifyContent: 'center',
        alignItems: 'center',
        padding: '15px 21px', // 1.5X from original
        fontSize: '24px', // 1.5X from original 16px
        fontWeight: '500',
        color: 'rgba(255, 255, 255, 0.9)',
        flexDirection: 'row'
    };
    
    // Main content row style
    const mainRowStyle = {
        display: 'flex',
        justifyContent: 'space-between',
        alignItems: 'center',
        width: '100%'
    };
    
    // Left side container for address and unit info
    const leftContainerStyle = {
        flex: '1',
        overflow: 'hidden',
        marginRight: '15px' // 1.5X from original 10px
    };
    
    // Larger street display (1.5X)
    const streetStyle = {
        fontSize: '30px', // 1.5X from original 20px
        fontWeight: '700',
        color: 'white',
        whiteSpace: 'nowrap',
        overflow: 'hidden',
        textOverflow: 'ellipsis',
        marginBottom: '3px' // 1.5X from original 2px
    };
    
    // Unit info style (1.5X)
    const unitStyle = {
        fontSize: '18px', // 1.5X from original 12px
        fontWeight: '500',
        color: 'rgba(255, 255, 255, 0.8)',
        display: 'flex',
        alignItems: 'center'
    };
    
    // Large heading display that spans both lines
    const largeHeadingStyle = {
        display: 'flex',
        alignItems: 'center',
        justifyContent: 'center',
        backgroundColor: 'rgba(0, 0, 0, 0.3)',
        borderRadius: '18px', // 1.5X from original 12px
        padding: '12px', // 1.5X from original 8px
        minWidth: '75px', // 1.5X from original 50px
        height: '100%',
        alignSelf: 'stretch'
    };
    
    // Large compass direction text (1.5X)
    const largeCompassStyle = {
        fontSize: '36px', // 1.5X from original 24px
        fontWeight: '700',
        color: 'white',
        lineHeight: '1'
    };
    
    // Style for the intersection/exit info row (1.5X)
    const infoRowStyle = {
        fontSize: '21px', // 1.5X from original 14px
        fontWeight: '500',
        color: 'rgba(255, 255, 255, 0.9)',
        marginTop: '9px', // 1.5X from original 6px
        borderTop: '1px solid rgba(255, 255, 255, 0.1)',
        paddingTop: '6px', // 1.5X from original 4px
        whiteSpace: 'nowrap',
        overflow: 'hidden',
        textOverflow: 'ellipsis'
    };
    
    // Extract address from Nominatim or create cross streets format
    const getFormattedAddress = (vehicle) => {
        if (!vehicle) return null;
        
        // If we already have an address from reverse geocoding
        if (vehicle.address) {
            // Parse the address information to show house number and street name
            const addressParts = vehicle.address.split(',');
            
            // Extract useful information from OpenStreetMap response
            if (vehicle.addressDetails && vehicle.addressDetails.house_number && vehicle.addressDetails.road) {
                return `${vehicle.addressDetails.house_number} ${vehicle.addressDetails.road}`;
            }
            
            // If we have a structured house_number and road, show them combined
            const firstPart = addressParts[0].trim();
            // Check if the first part already has both number and street
            if (/^\d+\s+\w+/.test(firstPart)) {
                return firstPart;
            } else if (addressParts.length > 1) {
                // Try to combine first two parts if first part seems to be just a number
                if (/^\d+$/.test(firstPart.trim()) && addressParts[1].trim()) {
                    return `${firstPart} ${addressParts[1].trim()}`;
                }
            }
            
            return firstPart;
        }
        
        // Fallback if no address is available
        return `${vehicle.latitude.toFixed(5)}, ${vehicle.longitude.toFixed(5)}`;
    };
    
    // If no vehicle is selected, show the placeholder
    if (!followedVehicle) {
        return (
            <div style={emptyStatusStyle}>
                <div>Select a vehicle to track</div>
            </div>
        );
    }
    
    // For string value (just display name)
    if (typeof followedVehicle === 'string') {
        return (
            <div style={statusBarStyle}>
                <div style={mainRowStyle}>
                    <div style={{ 
                        fontSize: '27px',  // 1.5X from original 18px
                        fontWeight: '600',
                        flex: '1'
                    }}>
                        {followedVehicle}
                    </div>
                    <div style={{ 
                        fontSize: '18px',  // 1.5X from original 12px
                        opacity: 0.8,
                        backgroundColor: 'rgba(0, 0, 0, 0.3)',
                        borderRadius: '12px',  // 1.5X from original 8px
                        padding: '4.5px 9px'  // 1.5X from original 3px 6px
                    }}>
                        Following
                    </div>
                </div>
            </div>
        );
    }
    
    // Formatted address - highest priority
    const formattedAddress = getFormattedAddress(followedVehicle);
    const compassDir = getCompassDirection(followedVehicle.heading);
    
    // Determine what additional info to show (exit or intersection) - prefer exit if on highway
    const showExitInfo = followedVehicle.nearestExit && followedVehicle.nearestExit.length > 0;
    const showIntersectionInfo = followedVehicle.nearestIntersection && followedVehicle.nearestIntersection.length > 0;
    const showNextIntersection = followedVehicle.nextIntersection && followedVehicle.nextIntersection.length > 0;
    
    // For object with full vehicle data - with large heading on right
    return (
        <div style={statusBarStyle}>
            <div style={mainRowStyle}>
                {/* Left side: Address and unit info */}
                <div style={leftContainerStyle}>
                    <div style={streetStyle}>
                        {formattedAddress}
                    </div>
                    <div style={unitStyle}>
                        <span>{followedVehicle.displayName}</span>
                        <span style={{ 
                            marginLeft: '7.5px',  // 1.5X from original 5px
                            fontSize: '16.5px',   // 1.5X from original 11px
                            opacity: 0.7,
                            fontStyle: 'italic'
                        }}>
                            (Following)
                        </span>
                    </div>
                </div>
                
                {/* Right side: Large heading indicator */}
                <div style={largeHeadingStyle}>
                    <div style={largeCompassStyle}>
                        {compassDir}
                    </div>
                </div>
            </div>
            
            {/* Intersection or exit info row - with preference for nextIntersection if available */}
            {(showNextIntersection || showExitInfo || showIntersectionInfo) && (
                <div style={infoRowStyle}>
                    {showNextIntersection ? 
                        followedVehicle.nextIntersection : 
                        showExitInfo ? 
                            followedVehicle.nearestExit : 
                            showIntersectionInfo ? 
                                followedVehicle.nearestIntersection : 
                                ''}
                </div>
            )}
        </div>
    );
};

// Zoom Controls Component - Update position to be higher to avoid overlap
const ZoomControls = () => {
    const map = useMap();
    
    const controlsContainerStyle = {
        position: 'fixed',
        right: '15px',           // Reduced from 20px
        bottom: '70px',          // Increased from 80px to move higher above buttons
        display: 'flex',
        flexDirection: 'column',
        gap: '8px',              // Reduced from 12px
        zIndex: 1000
    };
    
    const buttonStyle = {
        width: '36px',           // Reduced from 45px
        height: '36px',          // Reduced from 45px
        borderRadius: '50%',
        backgroundColor: 'rgba(25, 25, 25, 0.7)',
        backdropFilter: 'blur(10px)',
        WebkitBackdropFilter: 'blur(10px)',
        border: '1px solid rgba(255, 255, 255, 0.15)',
        color: 'white',
        fontSize: '20px',        // Reduced from 24px
        display: 'flex',
        alignItems: 'center',
        justifyContent: 'center',
        cursor: 'pointer',
        boxShadow: '0 4px 10px rgba(0, 0, 0, 0.2)',
        transition: 'transform 0.2s, background-color 0.2s'
    };
    
    const handleZoomIn = () => {
        map.setZoom(Math.min(map.getZoom() + 1, 18));
    };
    
    const handleZoomOut = () => {
        map.setZoom(Math.max(map.getZoom() - 1, 16));
    };
    
    return (
        <div style={controlsContainerStyle}>
            <button 
                style={buttonStyle} 
                onClick={handleZoomIn}
                title="Zoom In"
                className="mobile-button"
            >
                +
            </button>
            <button 
                style={buttonStyle} 
                onClick={handleZoomOut}
                title="Zoom Out"
                className="mobile-button"
            >
                −
            </button>
        </div>
    );
};

// Header component with logo and user info
const Header = ({ user, darkMode, toggleDarkMode }) => {
    const [userData, setUserData] = useState(null);
    const [avatarError, setAvatarError] = useState(false);
    
    useEffect(() => {
        // Use the raw user data from console logs
        try {
            // If we have user data from props, use it
            if (user && user.userName) {
                setUserData(user);
                return;
            }
            
            // Extract from URL query parameters
            const urlParams = new URLSearchParams(window.location.search);
            const userParam = urlParams.get('user');
            
            if (userParam) {
                // Try to parse the user parameter
                const parsedUser = JSON.parse(decodeURIComponent(userParam));
                console.log("Successfully parsed user data:", parsedUser);
                setUserData(parsedUser);
            } else {
                // Fallback to using hard-coded data from the logs
                console.log("Using fallback user data");
                setUserData({
                    userName: "Lt Brian Hess (RTC)",
                    userAvatar: "https://avatar-slack-edge.com/2023-10-23/6068087494647_b9a320_512.png",
                    permissions: {
                        admin: true,
                        fireGPS: true,
                        policeGPS: true,
                        starchase: true,
                        makeIncidents: true
                    }
                });
            }
        } catch (e) {
            console.error("Error parsing user data:", e);
            // Fallback if parsing fails
            setUserData({
                userName: "Lt Brian Hess",
                userAvatar: "https://avatar-slack-edge.com/2023-10-23/6068087494647_b9a320_512.png"
            });
        }
    }, [user]);
    
    const headerStyle = {
        position: 'fixed',
        top: 0,
        left: 0,
        right: 0,
        display: 'flex',
        justifyContent: 'space-between',
        alignItems: 'flex-start',
        padding: '10px 15px',
        zIndex: 1000,
        pointerEvents: 'none'
    };
    
    const logoStyle = {
        height: '60px',
        pointerEvents: 'auto'
    };
    
    const userSectionStyle = {
        display: 'flex',
        flexDirection: 'column',
        alignItems: 'flex-end',
        gap: '8px',
        pointerEvents: 'auto'
    };
    
    const userContainerStyle = {
        display: 'flex',
        alignItems: 'center',
        backgroundColor: 'rgba(25, 25, 25, 0.7)',
        backdropFilter: 'blur(10px)',
        WebkitBackdropFilter: 'blur(10px)',
        borderRadius: '20px',
        padding: '5px 12px',
        boxShadow: '0 2px 8px rgba(0, 0, 0, 0.2)',
        pointerEvents: 'auto',
        cursor: 'pointer'
    };
    
    const avatarStyle = {
        width: '32px',
        height: '32px',
        borderRadius: '50%',
        marginRight: '8px',
        border: '1px solid rgba(255, 255, 255, 0.3)'
    };
    
    const usernameStyle = {
        color: 'white',
        fontSize: '14px',
        fontWeight: '500'
    };
    
    const darkModeButtonStyle = {
        backgroundColor: 'rgba(25, 25, 25, 0.7)',
        backdropFilter: 'blur(10px)',
        WebkitBackdropFilter: 'blur(10px)',
        color: 'white',
        border: '1px solid rgba(255, 255, 255, 0.15)',
        borderRadius: '20px',
        padding: '5px 12px',
        fontSize: '14px',
        fontWeight: '500',
        cursor: 'pointer',
        boxShadow: '0 2px 8px rgba(0, 0, 0, 0.2)',
        display: 'flex',
        alignItems: 'center',
        justifyContent: 'center',
        width: '100%'
    };
    
    const handleLogout = () => {
        try {
            // Clear local storage first
            localStorage.removeItem('user');
            localStorage.removeItem('authToken');
            
            // Call server logout endpoint with proper headers
            fetch('/logout', {
                method: 'GET',
                credentials: 'include',
                headers: {
                    'Accept': 'application/json',
                    'Content-Type': 'application/json'
                }
            }).catch(err => console.error("Logout request error:", err));
        } catch (error) {
            console.error('Logout request failed:', error);
        } finally {
            // Redirect to login page
            window.location.href = '/login';
        }
    };
    
    // Only render if we have user data
    if (!userData) return null;
    
    return (
        <div style={headerStyle}>
            <img src={logo} alt="RTC Logo" style={logoStyle} />
            
            <div style={userSectionStyle}>
                <div style={userContainerStyle} onClick={handleLogout} title="Click to logout">
                    {userData.userAvatar && !avatarError ? (
                        <img 
                            src={userData.userAvatar} 
                            alt="Avatar" 
                            style={avatarStyle} 
                            onError={(e) => {
                                console.log("Avatar image failed to load");
                                setAvatarError(true); // Set error state to prevent further attempts
                            }}
                        />
                    ) : (
                        <div style={{
                            ...avatarStyle,
                            backgroundColor: '#3498db',
                            display: 'flex',
                            alignItems: 'center',
                            justifyContent: 'center',
                            color: 'white',
                            fontWeight: 'bold',
                            fontSize: '16px'
                        }}>
                            {userData.userName ? userData.userName.charAt(0).toUpperCase() : 'U'}
                        </div>
                    )}
                    <div style={usernameStyle}>{userData.userName}</div>
                </div>
                
                <button 
                    style={darkModeButtonStyle}
                    onClick={toggleDarkMode}
                >
                    <span style={{ marginRight: '8px', fontSize: '16px' }}>
                        {darkMode ? '☀️' : '🌙'}
                    </span>
                    {darkMode ? 'Light' : 'Dark'} Mode
                </button>
            </div>
        </div>
    );
};

