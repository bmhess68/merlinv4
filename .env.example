# Database
DB_NAME=incidentdb
DB_USER=wcpd
DB_DATABASE=incidentdb
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Google Maps
REACT_APP_GOOGLE_MAPS_API_KEY=
