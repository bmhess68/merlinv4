SLACK_BOT_TOKEN=
SLACK_WEBHOOK_URL=

# Session
SESSION_SECRET=

# App URLs
HOST=https://merlin.westchesterrtc.com
REACT_APP_API_URL=https://merlin.westchesterrtc.com
REACT_APP_API_BASE_URL=http://localhost:3000/api
REACT_APP_BACKEND_URL=http://localhost:3000
COOKIE_DOMAIN=.westchesterrtc.com
